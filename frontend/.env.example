# GitHub Pages (project site): must match repo name, with slashes, e.g. /telegram-music-bot-/
# VITE_BASE_PATH=/telegram-music-bot-/

# Base path for REST calls (no trailing slash). Dev: Vite proxies /api → backend.
# Docker frontend image: default /api (nginx proxies to the API service).
# Prod split domains: https://api.example.com
VITE_API_BASE_URL=/api

# Optional: paste a valid JWT (same JWT_SECRET as backend) if you skip POST /auth/dev
# VITE_DEV_BEARER_TOKEN=

# Staging/preview only (never on public prod): enables POST /auth/dev outside Vite dev mode.
# Backend must have ALLOW_DEV_AUTH=1 and VITE_API_BASE_URL must point to that API.
# VITE_PREVIEW_AUTH=1
