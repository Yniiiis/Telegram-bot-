# Copy to .env in the repo root for Docker Compose, or use per-app .env files for local dev.
# Never commit real .env files.

# --- PostgreSQL (Docker service `db`) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=music_bot

# --- Backend API (FastAPI) — use host `db` inside Docker, `localhost` on your machine ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/music_bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_from_BotFather
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
HITMOTOP_BASE_URL=https://rus.hitmotop.com
HITMOTOP_CHARTS_PATH=/2026

# --- Telegram bot (reads TELEGRAM_BOT_TOKEN; optional BOT_TOKEN in bot/.env for local runs) ---
WEBAPP_URL=https://your-frontend.example.com

# --- Frontend build (Docker only) ---
# Browser calls this path; nginx in the `frontend` service proxies /api to the API container.
VITE_API_BASE_URL=/api
