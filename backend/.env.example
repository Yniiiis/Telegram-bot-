# --- Без Docker: локальный файл SQLite (удобно для разработки) ---
# DATABASE_URL=sqlite+aiosqlite:///./data/music_bot.db
#
# --- Postgres (Docker / облако / локальный сервис) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/music_bot
# В Docker Compose хост `db` вместо localhost (см. корневой .env.example).

TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
# Local browser dev without Telegram: enables POST /auth/dev (never in production)
ALLOW_DEV_AUTH=0
# Optional: https://developer.jamendo.com/v3.0 (free client_id). If unset, Jamendo is skipped; mock fills in.
JAMENDO_CLIENT_ID=
# Catalog chain: zaycev, hitmotop, jamendo, lastfm, bandcamp, youtube_music, soundcloud, mock.
# Last.fm / Bandcamp: discovery + search; playback for those rows resolves via Zaycev/Hitmotop when possible.
# Example Jamendo+mock only: CATALOG_PROVIDER_CHAIN=jamendo,mock
CATALOG_PROVIDER_CHAIN=zaycev,hitmotop,jamendo,lastfm,bandcamp,youtube_music,soundcloud,mock
# https://www.last.fm/api/account/create — track.search + charts (optional but recommended for mood / search).
LASTFM_API_KEY=
# SoundCloud api-v2 client_id (DevTools → Network on soundcloud.com). Same API as e.g. github.com/r-park/soundcloud-ngrx
SOUNDCLOUD_CLIENT_ID=
# YouTube Music: search via ytmusicapi; playback uses yt-dlp (pip install yt-dlp). No API key for search.
# After parallel search across all providers in CATALOG_PROVIDER_CHAIN, drop weak hits below this score when possible.
# SEARCH_RELEVANCE_MIN_KEEP=0.26
# Deep search: extra query variants per provider (permutations, stripped brackets). More API load.
# SEARCH_DEEP_VARIANTS=1
# SEARCH_DEEP_MAX_VARIANTS=4
# When two sources return the same track (fingerprint), prefer earlier id: jamendo,soundcloud,youtube_music,zaycev,hitmotop,mock
# SEARCH_SOURCE_PRIORITY=jamendo,soundcloud,youtube_music,zaycev,hitmotop,mock
# Zaycev external API static key (see github.com/pixfid/go-zaycevnet); leave default or set your own.
ZAYCEV_STATIC_KEY=kmskoNkYHDnl3ol2
HITMOTOP_BASE_URL=https://rus.hitmotop.com
# Drop catalog rows that fail a quick audio URL probe before search/discovery lists (recommended).
# TRACK_AVAILABILITY_ENABLED=1
# TRACK_AVAILABILITY_CONCURRENCY=8
# TRACK_AVAILABILITY_TIMEOUT_SEC=2.5
# Upstream MP3 relay (first byte / stall).
# STREAM_CONNECT_TIMEOUT_SEC=5
# STREAM_READ_TIMEOUT_SEC=90
# Optional disk cache: if `STREAM_CACHE_DIR/{uuid}.audio` exists, /stream serves it (instant repeat plays).
# STREAM_CACHE_DIR=/opt/music-bot/cache/stream
# Per-track yt-dlp probe is slow; keep 0 for list endpoints unless you need strict YouTube filtering.
# TRACK_PROBE_YOUTUBE=0
# Background refresh for home New Hype (seconds). Default in code: 86400 (24h).
# NEW_RELEASES_REFRESH_SEC=86400
# On each app open, re-harvest at most every N seconds (default 900).
# NEW_RELEASES_USER_TOUCH_SEC=900
