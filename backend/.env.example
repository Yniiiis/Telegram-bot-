DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/music_bot

TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
ALLOW_DEV_AUTH=0

# Каталог только Hitmotop (rus.hitmotop.com).
HITMOTOP_BASE_URL=https://rus.hitmotop.com
HITMOTOP_CHARTS_PATH=/2026
# HITMOTOP_USE_JADE_SELECTORS=1
# HITMOTOP_SEARCH_START_PAGINATION=1
# HITMOTOP_PAGE_SIZE=48
# HITMOTOP_MIRROR_LOOKUP_URL=https://gde-hitmo.org/

# STREAM_CACHE_DIR=...
# NEW_RELEASES_REFRESH_SEC=86400

# httpx pools (catalog vs stream relay)
# HTTPX_CATALOG_MAX_CONNECTIONS=48
# HTTPX_CATALOG_MAX_KEEPALIVE=24
# HTTPX_CATALOG_TIMEOUT_SEC=60
# HTTPX_CATALOG_HTTP2=1
# HITMOTOP_WARMUP_ON_STARTUP=1
# HTTPX_STREAM_MAX_CONNECTIONS=96
# HTTPX_STREAM_MAX_KEEPALIVE=48

# Search cache (LRU + TTL)
# SEARCH_CACHE_TTL_SEC=300
# SEARCH_CACHE_MAX_ENTRIES=512

# API rate limit (0 = off): /search*, /stream/*
# API_RATE_LIMIT_PER_MINUTE=120

# Hitmotop retries (429 / 5xx)
# HITMOTOP_HTTP_MAX_ATTEMPTS=3
# HITMOTOP_HTTP_RETRY_BACKOFF_SEC=0.6
# HITMOTOP_SEARCH_QUICK_TIMEOUT_SEC=12
# HITMOTOP_SEARCH_NORMAL_TIMEOUT_SEC=22
# HITMOTOP_LOG_PARSE_MS=1
